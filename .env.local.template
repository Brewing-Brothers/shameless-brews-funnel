# Shameless Brews Environment Variables
# Copy this file to .env.local and fill in the values

# Google Sheets Backend (Apps Script Web App URL)
# Deploy the APPS_SCRIPT.gs as a Web App and paste the URL here
APPS_SCRIPT_WEB_APP_URL=

# Email Marketing (Phase 3)
KLAVIYO_API_KEY=

# Stripe (Phase 2)
# Get keys from: https://dashboard.stripe.com/test/apikeys
# IMPORTANT: STRIPE_SECRET_KEY is server-side only — NEVER use NEXT_PUBLIC_ prefix
STRIPE_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# Stripe Price IDs (create products in Stripe Dashboard → Products)
# Single: $13, Double: $21, 6-Pack: $45
STRIPE_PRICE_SINGLE=price_xxxx
STRIPE_PRICE_DOUBLE=price_xxxx
STRIPE_PRICE_SIXPACK=price_xxxx

# Stripe Webhook Secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Stripe enabled toggle - flip to 'true' ONLY after all above are configured
NEXT_PUBLIC_STRIPE_ENABLED=false

# Theme - DO NOT CHANGE
NEXT_PUBLIC_THEME=organic

# Urgency Settings
NEXT_PUBLIC_URGENCY_HOURS=8
NEXT_PUBLIC_BATCH_SIZE=47

# Base URL (update for production)
NEXT_PUBLIC_BASE_URL=https://shamelessbrews.com
